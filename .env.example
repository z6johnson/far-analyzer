ANTHROPIC_MODEL=claude-sonnet-4-6

# Primary path: LiteLLM proxy (Triton AI at UCSD).
LITELLM_API_KEY=
LITELLM_BASE_URL=https://tritonai-api.ucsd.edu

# Fallback path: direct Anthropic API. Used when LiteLLM returns auth / 5xx /
# 429 / network errors. Recommended — lets the app ride out proxy outages.
ANTHROPIC_API_KEY=
